---
import HeaderLink from './HeaderLink.astro';
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, getTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const base = `/${lang}`;
---

<header>
	<nav>
		<div class="nav-brand">
			<a href={`${base}/`} class="nav-logo">
				<img src="/favicon.svg" alt="GeoLab" class="logo-icon" />
			</a>
			<div class="nav-brand-text">
				<h2><a href={`${base}/`}>GeoLab</a></h2>
				<p class="nav-subtitle">{t('header.subtitle')}</p>
			</div>
		</div>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href={`${base}/`}>{t('nav.home')}</HeaderLink>
				<HeaderLink href={`${base}/research`}>{t('nav.research')}</HeaderLink>
				<HeaderLink href={`${base}/publications`}>{t('nav.publications')}</HeaderLink>
				<HeaderLink href={`${base}/teaching`}>{t('nav.teaching')}</HeaderLink>
				<HeaderLink href={`${base}/cv`}>{t('nav.cv')}</HeaderLink>
				<HeaderLink href={`${base}/resources`}>{t('nav.resources')}</HeaderLink>
				<HeaderLink href={`${base}/news`}>{t('nav.news')}</HeaderLink>
				<HeaderLink href={`${base}/contact`}>{t('nav.contact')}</HeaderLink>
			</div>
			<LanguagePicker />
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: white;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5em 0;
		max-width: 1200px;
		margin: 0 auto;
	}

	.nav-brand {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-shrink: 0;
	}

	.nav-logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		transition: transform 0.2s ease;
	}

	.nav-logo:hover {
		transform: scale(1.05);
	}

	.logo-icon {
		width: 64px;
		height: 64px;
		display: block;
		flex-shrink: 0;
		border: none;
		outline: none;
		box-shadow: none;
	}

	.nav-brand-text {
		display: flex;
		flex-direction: column;
	}

	.nav-brand h2 {
		margin: 0;
		font-size: 1.6em;
		font-weight: 700;
	}

	.nav-brand h2 a {
		text-decoration: none;
		color: rgb(var(--black));
	}

	.nav-subtitle {
		margin: 0.2em 0 0 0;
		font-size: 0.9em;
		color: rgb(var(--gray));
		font-weight: 400;
		white-space: nowrap;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 0;
	}

	.internal-links {
		display: flex;
		gap: 1.5em;
		flex-wrap: wrap;
		align-items: center;
	}

	.internal-links a {
		padding: 0.5em 0;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95em;
		border-bottom: 2px solid transparent;
		transition: all 0.2s;
		position: relative;
	}

	.internal-links a:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.internal-links a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	@media (max-width: 900px) {
		header {
			padding: 0 1em;
		}

		nav {
			flex-direction: column;
			gap: 1em;
			align-items: flex-start;
		}

		.nav-right {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75em;
			width: 100%;
		}

		.internal-links {
			gap: 1em;
			justify-content: flex-start;
			width: 100%;
			overflow-x: auto;
			padding-bottom: 0.5em;
		}

		.internal-links a {
			font-size: 0.9em;
			white-space: nowrap;
		}
	}

	@media (max-width: 480px) {
		.nav-brand {
			gap: 0.75em;
		}

		.logo-icon {
			width: 56px;
			height: 56px;
		}

		.nav-brand h2 {
			font-size: 1.4em;
		}

		.nav-subtitle {
			font-size: 0.8em;
		}

		.internal-links {
			gap: 0.8em;
		}

		.internal-links a {
			font-size: 0.85em;
		}
	}
</style>
