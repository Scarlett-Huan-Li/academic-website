---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'hu' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
const htmlLang = lang === 'zh' ? 'zh-Hans' : lang;
---
<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${t('research.title')} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>{t('research.title')}</h1>
				<p class="page-subtitle">{t('research.subtitle')}</p>
			</div>

			<section class="research-overview">
				<h2>{t('research.overview.heading')}</h2>
				<p>{t('research.overview.text')}</p>
			</section>

			<section class="research-areas">
				<h2>{t('research.areas.heading')}</h2>
				<div class="areas-grid">
					<div class="area-card">
						<div class="area-icon">🛰️</div>
						<h3>{t('research.areas.rs.title')}</h3>
						<p>{t('research.areas.rs.desc')}</p>
						<ul>
							<li>{t('research.areas.rs.li1')}</li>
							<li>{t('research.areas.rs.li2')}</li>
							<li>{t('research.areas.rs.li3')}</li>
						</ul>
					</div>
					<div class="area-card">
						<div class="area-icon">🧊</div>
						<h3>{t('research.areas.cryo.title')}</h3>
						<p>{t('research.areas.cryo.desc')}</p>
						<ul>
							<li>{t('research.areas.cryo.li1')}</li>
							<li>{t('research.areas.cryo.li2')}</li>
							<li>{t('research.areas.cryo.li3')}</li>
							<li>{t('research.areas.cryo.li4')}</li>
						</ul>
					</div>
					<div class="area-card">
						<div class="area-icon">🌊</div>
						<h3>{t('research.areas.water.title')}</h3>
						<p>{t('research.areas.water.desc')}</p>
						<ul>
							<li>{t('research.areas.water.li1')}</li>
							<li>{t('research.areas.water.li2')}</li>
							<li>{t('research.areas.water.li3')}</li>
						</ul>
					</div>
					<div class="area-card">
						<div class="area-icon">🌿</div>
						<h3>{t('research.areas.eco.title')}</h3>
						<p>{t('research.areas.eco.desc')}</p>
						<ul>
							<li>{t('research.areas.eco.li1')}</li>
							<li>{t('research.areas.eco.li2')}</li>
							<li>{t('research.areas.eco.li3')}</li>
						</ul>
					</div>
					<div class="area-card">
						<div class="area-icon">📊</div>
						<h3>{t('research.areas.big.title')}</h3>
						<p>{t('research.areas.big.desc')}</p>
						<ul>
							<li>{t('research.areas.big.li1')}</li>
							<li>{t('research.areas.big.li2')}</li>
							<li>{t('research.areas.big.li3')}</li>
						</ul>
					</div>
					<div class="area-card">
						<div class="area-icon">🏙️</div>
						<h3>{t('research.areas.socio.title')}</h3>
						<p>{t('research.areas.socio.desc')}</p>
						<ul>
							<li>{t('research.areas.socio.li1')}</li>
							<li>{t('research.areas.socio.li2')}</li>
							<li>{t('research.areas.socio.li3')}</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="current-projects">
				<h2>{t('research.projects.heading')}</h2>
				<div class="projects-grid">
					<div class="project-card">
						<div class="project-header">
							<h3>Perceptual AI Framework for Integrated Satellite and Multi-Source Aquatic Environment Monitoring</h3>
							<div class="project-meta">
								<span class="timeline">2025</span>
								<span class="funding">HUN-REN – NTU AI Research Cooperation Programme 2025</span>
							</div>
						</div>
						<p>Development of advanced AI frameworks for integrated satellite and multi-source aquatic environment monitoring. This project aims to create perceptual AI systems that combine satellite data with multiple environmental data sources for comprehensive aquatic ecosystem analysis.</p>
						<div class="project-tags">
							<span class="tag">Artificial Intelligence</span>
							<span class="tag">Satellite Remote Sensing</span>
							<span class="tag">Aquatic Environment</span>
							<span class="tag">Multi-Source Data</span>
						</div>
					</div>

					<div class="project-card">
						<div class="project-header">
							<h3>Mining spatio-temporal patterns of 40-year surface water temperature for lakes and rivers in the Pannonian ecoregion</h3>
							<div class="project-meta">
								<span class="timeline">2023–2024</span>
								<span class="funding">European Space Agency Network of Resources (NoR)</span>
							</div>
						</div>
						<p>Analysis of long-term water temperature trends and heatwaves in Central European lakes and rivers using remote sensing and big data analytics. This project aims to understand the impacts of climate change on aquatic ecosystems in the Pannonian region.</p>
						<div class="project-tags">
							<span class="tag">Remote Sensing</span>
							<span class="tag">Water Temperature</span>
							<span class="tag">Big Data</span>
							<span class="tag">Climate Change</span>
						</div>
					</div>

					<div class="project-card">
						<div class="project-header">
							<h3>Retrieving key parameters of circum-Antarctic sea ice with altimeter satellites and their spatio-temporal changes</h3>
							<div class="project-meta">
								<span class="timeline">2020–2022</span>
								<span class="funding">National Natural Science Foundation of China</span>
							</div>
						</div>
						<p>Development of algorithms for satellite altimetry to retrieve sea ice thickness and volume, and analysis of spatiotemporal variability in the Antarctic. This research contributes to understanding polar climate dynamics.</p>
						<div class="project-tags">
							<span class="tag">Cryosphere</span>
							<span class="tag">Satellite Altimetry</span>
							<span class="tag">Sea Ice</span>
							<span class="tag">Antarctic</span>
						</div>
					</div>

					<div class="project-card">
						<div class="project-header">
							<h3>Retrieving Antarctic sea-ice thickness and volume from ICESat and spatio-temporal variability analysis</h3>
							<div class="project-meta">
								<span class="timeline">2019–2021</span>
								<span class="funding">China Post-doc Foundation</span>
							</div>
						</div>
						<p>Spatiotemporal analysis of Antarctic sea-ice thickness and volume using ICESat satellite data and innovative retrieval algorithms. This work provides critical insights into polar climate change.</p>
						<div class="project-tags">
							<span class="tag">Antarctic</span>
							<span class="tag">ICESat</span>
							<span class="tag">Sea Ice Thickness</span>
							<span class="tag">Climate Change</span>
						</div>
					</div>
				</div>
			</section>

			<section class="methodology">
				<h2>{t('research.methodology.heading')}</h2>
				<p>{t('research.methodology.text')}</p>

				<div class="methodology-grid">
					<div class="method-card">
						<h3>{t('research.methodology.rs.title')}</h3>
						<p>{t('research.methodology.rs.desc')}</p>
					</div>
					<div class="method-card">
						<h3>{t('research.methodology.gis.title')}</h3>
						<p>{t('research.methodology.gis.desc')}</p>
					</div>
					<div class="method-card">
						<h3>{t('research.methodology.collab.title')}</h3>
						<p>{t('research.methodology.collab.desc')}</p>
					</div>
				</div>
			</section>

			<section class="facilities">
				<h2>{t('research.facilities.heading')}</h2>
				<p>{t('research.facilities.text')}</p>
				<div class="facilities-grid">
					<div class="facility-card">
						<h3>{t('research.facilities.gee.title')}</h3>
						<p>{t('research.facilities.gee.desc')}</p>
					</div>
					<div class="facility-card">
						<h3>{t('research.facilities.hpc.title')}</h3>
						<p>{t('research.facilities.hpc.desc')}</p>
					</div>
					<div class="facility-card">
						<h3>{t('research.facilities.sw.title')}</h3>
						<p>{t('research.facilities.sw.desc')}</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		text-align: center;
		margin-bottom: 4em;
		padding: 2em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	.page-header h1 {
		margin-bottom: 0.5em;
		color: rgb(var(--black));
	}

	.page-subtitle {
		font-size: 1.2em;
		color: rgb(var(--gray));
		margin: 0;
		font-style: italic;
	}

	section {
		margin: 4em 0;
		padding: 2em 0;
	}

	section:first-of-type {
		margin-top: 0;
	}

	.research-overview {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 4em auto;
	}

	.research-overview p {
		font-size: 1.1em;
		line-height: 1.8;
		color: rgb(var(--gray));
	}

	.areas-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 2em;
		margin-top: 2em;
	}

	.area-card {
		padding: 2em;
		background: white;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
		transition: transform 0.2s;
	}

	.area-card:hover {
		transform: translateY(-5px);
	}

	.area-icon {
		font-size: 2.5em;
		margin-bottom: 1em;
		text-align: center;
	}

	.area-card h3 {
		margin-bottom: 1em;
		color: rgb(var(--black));
		font-size: 1.3em;
		text-align: center;
	}

	.area-card p {
		margin-bottom: 1.5em;
		color: rgb(var(--gray));
		line-height: 1.6;
	}

	.area-card ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.area-card li {
		padding: 0.5em 0;
		border-left: 3px solid var(--accent);
		padding-left: 1em;
		margin: 0.5em 0;
		color: rgb(var(--gray-dark));
	}

	.projects-grid {
		display: grid;
		gap: 2em;
		margin-top: 2em;
	}

	.project-card {
		padding: 2em;
		background: white;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
		border-left: 4px solid var(--accent);
	}

	.project-header h3 {
		margin-bottom: 0.5em;
		color: rgb(var(--black));
		font-size: 1.2em;
		line-height: 1.4;
	}

	.project-meta {
		display: flex;
		gap: 1em;
		margin-bottom: 1em;
		flex-wrap: wrap;
	}

	.timeline, .funding {
		background: rgb(var(--gray-light));
		padding: 0.3em 0.8em;
		border-radius: 15px;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
		font-weight: 500;
	}

	.project-card p {
		margin-bottom: 1.5em;
		color: rgb(var(--gray));
		line-height: 1.6;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
	}

	.tag {
		background: var(--accent);
		color: white;
		padding: 0.3em 0.8em;
		border-radius: 15px;
		font-size: 0.8em;
		font-weight: 500;
	}

	.methodology-grid, .facilities-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2em;
		margin-top: 2em;
	}

	.method-card, .facility-card {
		padding: 2em;
		background: white;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
		text-align: center;
	}

	.method-card h3, .facility-card h3 {
		margin-bottom: 1em;
		color: rgb(var(--black));
		font-size: 1.2em;
	}

	.method-card p, .facility-card p {
		color: rgb(var(--gray));
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.areas-grid {
			grid-template-columns: 1fr;
		}

		.methodology-grid, .facilities-grid {
			grid-template-columns: 1fr;
		}

		.project-meta {
			flex-direction: column;
			gap: 0.5em;
		}

		.page-header {
			padding: 1em 0;
			margin-bottom: 2em;
		}

		section {
			margin: 2em 0;
			padding: 1em 0;
		}
	}
</style>
