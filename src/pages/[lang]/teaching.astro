---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'hu' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
const htmlLang = lang === 'zh' ? 'zh-Hans' : lang;
---
<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${t('teaching.title')} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{t('teaching.title')}</h1>


			<section class="courses">
				<h2>{t('teaching.courses.heading')}</h2>
				<div class="course-list">
					<div class="course-card">
						<h3>Image Classification using Machine Learning with Google Earth Engine</h3>
						<p class="course-code">{t('teaching.courses.type')}</p>
						<p class="course-term">UiT the Arctic University of Norway, 2022</p>
						<p>{t('teaching.courses.c1.desc')}</p>
					</div>
					<div class="course-card">
						<h3>Remote Sensing of Cryosphere</h3>
						<p class="course-code">{t('teaching.courses.type')}</p>
						<p class="course-term">Peking University, 2022</p>
						<p>{t('teaching.courses.c2.desc')}</p>
					</div>
					<div class="course-card">
						<h3>Cryosphere: Snow Cover, Glacier, Polar Ice Sheet, and Sea Ice</h3>
						<p class="course-code">{t('teaching.courses.type')}</p>
						<p class="course-term">Peking University, 2021</p>
						<p>{t('teaching.courses.c3.desc')}</p>
					</div>
					<div class="course-card">
						<h3>Cryosphere</h3>
						<p class="course-code">{t('teaching.courses.type')}</p>
						<p class="course-term">Peking University, 2020</p>
						<p>{t('teaching.courses.c4.desc')}</p>
					</div>
					<div class="course-card">
						<h3>Sea Ice Thickness and Volume Retrieval for Antarctic and Glacier Extent Delineation on Tibetan Plateau</h3>
						<p class="course-code">{t('teaching.courses.type')}</p>
						<p class="course-term">Peking University, 2019</p>
						<p>{t('teaching.courses.c5.desc')}</p>
					</div>
				</div>
			</section>

			<section class="mentoring">
				<h2>{t('teaching.mentoring.heading')}</h2>
				<div class="supervision-categories">
					<div class="supervision-card">
						<h3>{t('teaching.mentoring.ugrad.title')}</h3>
						<ul>
							<li>{t('teaching.mentoring.ugrad.text')}</li>
						</ul>
					</div>
					<div class="supervision-card">
						<h3>{t('teaching.mentoring.masters.title')}</h3>
						<ul>
							<li>{t('teaching.mentoring.masters.text')}</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="teaching-resources">
				<h2>{t('teaching.resources.heading')}</h2>
				<div class="resources-grid">
					<div class="resource-card">
						<h3>{t('teaching.resources.r1.title')}</h3>
						<p>{t('teaching.resources.r1.desc')}</p>
						<a href="https://lihuan.projects.earthengine.app/view/chla4balaton" class="resource-link" target="_blank">{t('teaching.resources.view')}</a>
					</div>
					<div class="resource-card">
						<h3>{t('teaching.resources.r2.title')}</h3>
						<p>{t('teaching.resources.r2.desc')}</p>
						<a href="https://code.earthengine.google.com/?accept_repo=users/lihuan/Share_LakeBalaton" class="resource-link" target="_blank">{t('teaching.resources.view_code')}</a>
						<a href="https://lihuan.users.earthengine.app/view/balaton" class="resource-link" target="_blank">{t('teaching.resources.online_tool')}</a>
					</div>
					<div class="resource-card">
						<h3>{t('teaching.resources.r3.title')}</h3>
						<p>{t('teaching.resources.r3.desc')}</p>
						<a href="https://gist.github.com/scarlettlee/eda18ca801213429636e7a0764b5b59f" class="resource-link" target="_blank">{t('teaching.resources.view_code')}</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	section {
		margin: 2em 0;
		padding: 1em 0;
		border-top: 1px solid rgb(var(--gray-light));
	}

.course-list {
		display: grid;
		gap: 1.5em;
		margin-top: 1em;
	}

	.course-card {
		padding: 1.5em;
		background-color: white;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.course-code {
		color: var(--accent);
		font-weight: bold;
		margin: 0.5em 0;
	}

	.course-term {
		color: rgb(var(--gray));
		font-size: 0.9em;
		margin: 0.5em 0;
	}

	.course-links {
		margin-top: 1em;
		display: flex;
		gap: 1em;
	}

	.course-link {
		padding: 0.3em 0.8em;
		background-color: rgb(var(--gray-light));
		border-radius: 4px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.9em;
		transition: background-color 0.2s;
	}

	.course-link:hover {
		background-color: rgb(var(--gray));
		color: white;
	}

	.supervision-categories {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.5em;
		margin-top: 1em;
	}

	.supervision-card {
		padding: 1.5em;
		background-color: white;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.supervision-card ul {
		list-style-type: none;
		padding: 0;
	}

	.supervision-card li {
		margin: 1em 0;
		padding-left: 1em;
		border-left: 3px solid var(--accent);
	}

	.resources-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5em;
		margin-top: 1em;
	}

	.resource-card {
		padding: 1.5em;
		background-color: white;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.resource-link {
		display: inline-block;
		margin-top: 1em;
		padding: 0.5em 1em;
		background-color: var(--accent);
		color: white;
		border-radius: 4px;
		text-decoration: none;
		transition: background-color 0.2s;
	}

	.resource-link:hover {
		background-color: var(--accent-dark);
	}
</style>
