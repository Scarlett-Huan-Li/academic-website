---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'hu' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
const htmlLang = lang === 'zh' ? 'zh-Hans' : lang;
---
<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${t('resources.title')} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{t('resources.title')}</h1>
			<p class="page-subtitle">{t('resources.subtitle')}</p>

			<section class="research-tools">
				<h2>{t('resources.tools.heading')}</h2>
				<div class="tools-grid">
					<div class="tool-card">
						<h3>Chlorophyll-a Inspection Software for Lake Balaton</h3>
						<p>{t('resources.tools.t1.desc')}</p>
						<div class="tool-links">
							<a href="https://lihuan.projects.earthengine.app/view/chla-balaton" class="resource-btn" target="_blank">{t('resources.tools.view')}</a>
							<a href="https://doi.org/10.1016/j.ecoinf.2025.103245" class="resource-btn" target="_blank">{t('resources.tools.paper')}</a>
						</div>
					</div>
					<div class="tool-card">
						<h3>Lake Balaton Water Temperature Explorer</h3>
						<p>{t('resources.tools.t2.desc')}</p>
						<div class="tool-links">
							<a href="https://lihuan.users.earthengine.app/view/balaton" class="resource-btn" target="_blank">{t('resources.tools.view')}</a>
							<a href="https://doi.org/10.1016/j.jhydrol.2024.131672" class="resource-btn" target="_blank">{t('resources.tools.paper')}</a>
						</div>
					</div>
					<div class="tool-card">
						<h3>Lake Chad Area Change Inspector</h3>
						<p>{t('resources.tools.t3.desc')}</p>
						<div class="tool-links">
							<a href="https://lihuan.users.earthengine.app/view/lakechad" class="resource-btn" target="_blank">{t('resources.tools.view')}</a>
							<a href="https://doi.org/10.1016/j.jhydrol.2021.126934" class="resource-btn" target="_blank">{t('resources.tools.paper')}</a>
						</div>
					</div>
					<div class="tool-card">
						<h3>Global Landsat Mosaic Generator</h3>
						<p>{t('resources.tools.t4.desc')}</p>
						<div class="tool-links">
							<a href="https://lihuan.projects.earthengine.app/view/user-ready-mosaic" class="resource-btn" target="_blank">{t('resources.tools.view')}</a>
							<a href="https://doi.org/10.1016/j.envsoft.2018.10.004" class="resource-btn" target="_blank">{t('resources.tools.paper')}</a>
						</div>
					</div>
				</div>
			</section>

			<section class="datasets">
				<h2>{t('resources.datasets.heading')}</h2>
				<div class="dataset-list">
					<div class="dataset-card">
						<h3>150-year Daily Water Temperature Record (1870–2021) for Lakes and Rivers in Central Europe</h3>
						<p>{t('resources.datasets.d1.desc')}</p>
						<div class="dataset-meta">
							<span>Format: Various</span>
							<span>Last Updated: 2024</span>
						</div>
						<div class="dataset-links">
							<a href="https://doi.org/10.6084/m9.figshare.25549561.v1" class="resource-btn" target="_blank">{t('resources.datasets.view')}</a>
						</div>
					</div>
					<div class="dataset-card">
						<h3>Global Water Budget with Correction Algorithm</h3>
						<p>{t('resources.datasets.d2.desc')}</p>
						<div class="dataset-meta">
							<span>Format: Various</span>
							<span>Last Updated: 2023</span>
						</div>
						<div class="dataset-links">
							<a href="https://doi.org/10.6084/m9.figshare.20208026" class="resource-btn" target="_blank">{t('resources.datasets.view')}</a>
						</div>
					</div>
					<div class="dataset-card">
						<h3>Seasonal and Monthly Circum-Antarctic Sea Ice Thickness (10 km grid) based on ICESat/ICESat-2</h3>
						<p>{t('resources.datasets.d3.desc')}</p>
						<div class="dataset-meta">
							<span>Format: Various</span>
							<span>Last Updated: 2021</span>
						</div>
						<div class="dataset-links">
							<a href="https://doi.org/10.6084/m9.figshare.12910121" class="resource-btn" target="_blank">{t('resources.datasets.view')}</a>
						</div>
					</div>
				</div>
			</section>

			<section class="code">
				<h2>{t('resources.code.heading')}</h2>
				<div class="code-grid">
					<!-- NEW: Shallow Water Chlorophyll-a Analysis -->
					<div class="code-card featured">
						<h3>Shallow Lake Chlorophyll-a Dynamics Analysis (2025)</h3>
						<p>{t('resources.code.c1.desc')}</p>
						<div class="code-meta">
							<span>Language: Python</span>
							<span>License: MIT</span>
							<span>📄 <a href="https://doi.org/10.1016/j.watres.2025.124925" target="_blank" style="color: var(--accent);">Water Research 2025</a></span>
						</div>
						<div class="code-links">
							<a href="https://github.com/Scarlett-Huan-Li/shallow-water-chla" class="resource-btn" target="_blank">💻 {t('resources.code.view')}</a>
						</div>
					</div>

					<div class="code-card">
						<h3>Google Earth Engine Open Code for Lake Balaton</h3>
						<p>{t('resources.code.c2.desc')}</p>
						<div class="code-meta">
							<span>Language: JavaScript</span>
							<span>Platform: Google Earth Engine</span>
						</div>
						<div class="code-links">
							<a href="https://code.earthengine.google.com/?accept_repo=users/lihuan/Share_LakeBalaton" class="resource-btn" target="_blank">{t('resources.code.view')}</a>
						</div>
					</div>
					<div class="code-card">
						<h3>Polar Sea Ice Key Parameter Retrieval Algorithm Software V1.0</h3>
						<p>{t('resources.code.c3.desc')}</p>
						<div class="code-meta">
							<span>Language: Various</span>
							<span>License: Software Copyright</span>
						</div>
					</div>
					<div class="code-card">
						<h3>Global High-Quality Landsat Mosaic Generator</h3>
						<p>{t('resources.code.c4.desc')}</p>
						<div class="code-meta">
							<span>Language: JavaScript</span>
							<span>Platform: Google Earth Engine</span>
						</div>
						<div class="code-links">
							<a href="https://gist.github.com/scarlettlee/eda18ca801213429636e7a0764b5b59f" class="resource-btn" target="_blank">{t('resources.code.view')}</a>
						</div>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	section {
		margin: 2em 0;
		padding: 1em 0;
		border-top: 1px solid rgb(var(--gray-light));
	}

	.tools-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5em;
		margin-top: 1em;
	}

	.tool-card, .dataset-card {
		padding: 1.5em;
		background-color: white;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
		display: flex;
		flex-direction: column;
	}

	.tool-card > p,
	.dataset-card > p {
		flex-grow: 1;
		margin-bottom: 1em;
	}

	.code-card.featured {
		border-left: 4px solid var(--accent);
		background: linear-gradient(to right, rgba(var(--accent-rgb), 0.03), white);
	}

	.dataset-list {
		display: grid;
		gap: 1.5em;
		margin-top: 1em;
	}

	.tool-links, .dataset-links {
		margin-top: 1em;
		display: flex;
		gap: 1em;
		flex-wrap: nowrap;
	}

	.resource-btn {
		padding: 0.5em 1em;
		background-color: var(--accent);
		border-radius: 4px;
		text-decoration: none;
		color: white;
		font-size: 0.9em;
		font-weight: 500;
		transition: background-color 0.2s, transform 0.1s;
		display: inline-block;
	}

	.resource-btn:hover {
		background-color: var(--accent-dark);
		transform: translateY(-1px);
	}

	.dataset-meta {
		margin: 0 0 1em 0;
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}

	.tool-card .tool-links {
		margin-top: auto;
	}

	.dataset-card .dataset-meta {
		margin-top: auto;
	}

	.dataset-meta span {
		padding: 0.2em 0.5em;
		background-color: rgb(var(--gray-light));
		border-radius: 4px;
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
	}

	.code-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5em;
		margin-top: 1em;
	}

	.code-card {
		padding: 1.5em;
		background-color: white;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
		display: flex;
		flex-direction: column;
	}

	.code-card > p {
		flex-grow: 1;
		margin-bottom: 1em;
	}

	.code-meta {
		margin: 0 0 1em 0;
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}

	.code-meta span {
		padding: 0.2em 0.5em;
		background-color: rgb(var(--gray-light));
		border-radius: 4px;
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
	}

	.code-links {
		margin-top: auto;
		display: flex;
		gap: 1em;
		flex-wrap: nowrap;
	}

</style>
